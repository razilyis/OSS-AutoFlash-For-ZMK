<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <RootNamespace>AutoFlash</RootNamespace>
    <AssemblyName>AutoFlash</AssemblyName>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationIcon>Assets\AppIcon.ico</ApplicationIcon>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <Version>0.2.0</Version>
    <Product>AutoFlash for ZMK</Product>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Hardcodet.NotifyIcon.Wpf" Version="2.0.1" />
    <PackageReference Include="Meziantou.Framework.Win32.CredentialManager" Version="2.0.2" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Assets\TrayIcon.ico" />
  </ItemGroup>

</Project>
