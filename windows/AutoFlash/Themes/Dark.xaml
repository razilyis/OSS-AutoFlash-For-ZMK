<!-- Theme.swift の ThemePalette.dark を WPF リソース化したもの。全参照は DynamicResource で行う。 -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <Color x:Key="Theme.BackgroundColor">#0E131C</Color>
    <Color x:Key="Theme.BackgroundBottomColor">#0A0D13</Color>

    <SolidColorBrush x:Key="Theme.Mint" Color="#8FE6C7"/>
    <SolidColorBrush x:Key="Theme.Purple" Color="#A38FFA"/>
    <SolidColorBrush x:Key="Theme.Orange" Color="#EDB35C"/>
    <SolidColorBrush x:Key="Theme.TextPrimary" Color="#EBEDF5"/>
    <SolidColorBrush x:Key="Theme.TextSecondary" Color="#94A1BD"/>
    <SolidColorBrush x:Key="Theme.Divider" Color="#333D52"/>
    <SolidColorBrush x:Key="Theme.RowSelected" Color="#38A38FFA"/>
    <SolidColorBrush x:Key="Theme.BadgeText" Color="#C7000000"/>
    <SolidColorBrush x:Key="Theme.BorderOverlay" Color="#14FFFFFF"/>
    <SolidColorBrush x:Key="Theme.MintDim" Color="#298FE6C7"/>
    <SolidColorBrush x:Key="Theme.PurpleDim" Color="#29A38FFA"/>
    <SolidColorBrush x:Key="Theme.OrangeDim" Color="#29EDB35C"/>
    <SolidColorBrush x:Key="Theme.MintBorder" Color="#598FE6C7"/>
    <SolidColorBrush x:Key="Theme.PurpleBorder" Color="#59A38FFA"/>
    <SolidColorBrush x:Key="Theme.OrangeBorder" Color="#59EDB35C"/>

    <LinearGradientBrush x:Key="Theme.PanelBackground" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#0E131C" Offset="0"/>
        <GradientStop Color="#0A0D13" Offset="1"/>
    </LinearGradientBrush>

    <sys:Double x:Key="Theme.MaterialOpacity">0.55</sys:Double>
</ResourceDictionary>
