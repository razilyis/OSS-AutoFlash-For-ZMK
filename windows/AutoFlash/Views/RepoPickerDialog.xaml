<Window x:Class="AutoFlash.Views.RepoPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fetch Repositories from GitHub"
        Width="460" Height="460" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <DockPanel Margin="14">
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <Button Content="Close" DockPanel.Dock="Right" Padding="10,4" IsCancel="True"/>
            <TextBlock Text="Fetch Repositories from GitHub" FontWeight="SemiBold" FontSize="13"
                       VerticalAlignment="Center"/>
        </DockPanel>
        <TextBox x:Name="SearchBox" DockPanel.Dock="Top" Margin="0,0,0,8" Padding="6,4"
                 TextChanged="OnSearchChanged"/>
        <Grid>
            <TextBlock x:Name="LoadingText" Text="Loading repositories…" HorizontalAlignment="Center"
                       VerticalAlignment="Center" Foreground="Gray"/>
            <TextBlock x:Name="ErrorText" Foreground="#C0392B" TextWrapping="Wrap"
                       VerticalAlignment="Top" Visibility="Collapsed"/>
            <TextBlock x:Name="EmptyText" Text="No repositories found." HorizontalAlignment="Center"
                       VerticalAlignment="Center" Foreground="Gray" Visibility="Collapsed"/>
            <ListBox x:Name="ResultList" Visibility="Collapsed"
                     HorizontalContentAlignment="Stretch"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <DockPanel Margin="2">
                            <StackPanel DockPanel.Dock="Right" VerticalAlignment="Center">
                                <TextBlock Text="✓ Added" Foreground="Green" FontSize="11"
                                           Visibility="{Binding AddedVisibility}"/>
                                <Button Content="Add" Padding="12,2" Click="OnAddClick" Tag="{Binding}"
                                        Visibility="{Binding AddVisibility}"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="{Binding FullName}"/>
                                <TextBlock Text="{Binding DefaultBranchText}" FontSize="11" Foreground="Gray"/>
                            </StackPanel>
                        </DockPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </DockPanel>
</Window>
