<Window x:Class="AutoFlash.Views.FlashConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" ShowInTaskbar="False" SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner" Topmost="True">
    <Border CornerRadius="14" BorderThickness="1" Padding="22,18" MinWidth="320"
            Background="{DynamicResource Theme.PanelBackground}"
            BorderBrush="{DynamicResource Theme.Divider}">
        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock x:Name="IconText" Style="{StaticResource Glyph}" Text="&#xE7BA;" FontSize="22"
                           Foreground="{DynamicResource Theme.Orange}" Margin="0,0,10,0"/>
                <TextBlock x:Name="TitleText" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"
                           Foreground="{DynamicResource Theme.TextPrimary}"/>
            </StackPanel>
            <TextBlock x:Name="MessageText" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,16"
                       Foreground="{DynamicResource Theme.TextSecondary}"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Style="{StaticResource DialogButton}" IsCancel="True" Margin="0,0,8,0"/>
                <Button x:Name="FlashButton" Content="Flash" Style="{StaticResource DialogPrimaryButton}"
                        IsDefault="True" Click="OnFlashClick"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
