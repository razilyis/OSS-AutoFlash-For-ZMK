<Window x:Class="AutoFlash.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:AutoFlash.Views"
        Title="AutoFlash for ZMK Settings"
        Width="660" Height="560" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        PreviewKeyDown="OnWindowPreviewKeyDown">
    <TabControl x:Name="Tabs" Margin="10">

        <!-- General -->
        <TabItem Header="General">
            <StackPanel Margin="18">
                <TextBlock Text="Startup" FontWeight="SemiBold"/>
                <CheckBox x:Name="LaunchAtLoginCheck" Content="Launch at login" Margin="0,10,0,2"
                          Checked="OnLaunchAtLoginToggled" Unchecked="OnLaunchAtLoginToggled"/>
                <TextBlock x:Name="LoginErrorText" Foreground="#C0392B" FontSize="11"
                           TextWrapping="Wrap" Visibility="Collapsed"/>

                <Separator Margin="0,16,0,12"/>
                <TextBlock Text="Appearance" FontWeight="SemiBold"/>
                <DockPanel Margin="0,10,0,0">
                    <TextBlock Text="Color Theme" VerticalAlignment="Center" Width="150"/>
                    <ComboBox x:Name="ThemeSelect" Width="140" HorizontalAlignment="Left"
                              SelectionChanged="OnThemeChanged">
                        <ComboBoxItem Content="Dark"/>
                        <ComboBoxItem Content="Light"/>
                    </ComboBox>
                </DockPanel>
                <DockPanel Margin="0,10,0,0">
                    <TextBlock Text="Window Transparency" VerticalAlignment="Center" Width="150"/>
                    <TextBlock x:Name="OpacityLabel" DockPanel.Dock="Right" Width="44"
                               TextAlignment="Right" VerticalAlignment="Center" Foreground="Gray"/>
                    <Slider x:Name="OpacitySlider" Minimum="0.4" Maximum="1.0"
                            VerticalAlignment="Center" ValueChanged="OnOpacityChanged"/>
                </DockPanel>

                <!-- フラッシュパネルのテーマプレビュー -->
                <Grid Margin="0,16,0,0" Height="86">
                    <Border x:Name="PreviewBackground" CornerRadius="14"
                            Background="{DynamicResource Theme.PanelBackground}"/>
                    <Border CornerRadius="14" BorderThickness="1"
                            BorderBrush="{DynamicResource Theme.BorderOverlay}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border Background="{DynamicResource Theme.Mint}" CornerRadius="13" Padding="12,6" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource Glyph}" Text="&#xE964;" FontSize="12"
                                           Foreground="{DynamicResource Theme.BadgeText}" Margin="0,0,6,0"/>
                                <TextBlock Text="Sample" FontFamily="{StaticResource MonoFont}" FontSize="13"
                                           FontWeight="SemiBold" Foreground="{DynamicResource Theme.BadgeText}"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource Theme.OrangeDim}" CornerRadius="10" Padding="8,3" Margin="0,0,8,0"
                                BorderThickness="1" BorderBrush="{DynamicResource Theme.OrangeBorder}">
                            <TextBlock Text="Esc Back/Close" FontFamily="{StaticResource MonoFont}" FontSize="11"
                                       Foreground="{DynamicResource Theme.Orange}"/>
                        </Border>
                        <Border Background="{DynamicResource Theme.PurpleDim}" CornerRadius="10" Padding="8,3"
                                BorderThickness="1" BorderBrush="{DynamicResource Theme.PurpleBorder}">
                            <TextBlock x:Name="PreviewHotKeyText" FontFamily="{StaticResource MonoFont}" FontSize="11"
                                       Foreground="{DynamicResource Theme.Purple}"/>
                        </Border>
                    </StackPanel>
                </Grid>
                <TextBlock x:Name="PreviewCaption" FontSize="11" Foreground="Gray" Margin="0,6,0,0"/>
            </StackPanel>
        </TabItem>

        <!-- Hotkeys -->
        <TabItem Header="Hotkeys">
            <StackPanel Margin="18">
                <TextBlock Text="Hotkeys" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <views:HotKeyRecorderControl x:Name="GithubHotKeyRow"/>
                <views:HotKeyRecorderControl x:Name="RegisteredHotKeyRow"/>
                <TextBlock Text="Click, then press a new combination that includes Ctrl / Alt / Win. Press Esc to cancel."
                           FontSize="11" Foreground="Gray" Margin="0,8,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </TabItem>

        <!-- GitHub Firmware -->
        <TabItem Header="GitHub Firmware">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="18">
                    <TextBlock Text="GitHub Personal Access Token" FontWeight="SemiBold"/>
                    <TextBlock FontSize="11" Foreground="Gray" TextWrapping="Wrap" Margin="0,4,0,6">
                        Required to download Actions artifacts. Create one at
                        <Run FontWeight="SemiBold">github.com/settings/personal-access-tokens</Run>
                        (Fine-grained token) with <Run FontWeight="SemiBold">Actions: Read-only</Run> and
                        <Run FontWeight="SemiBold">Contents: Read-only</Run> permissions for the repositories below.
                    </TextBlock>
                    <PasswordBox x:Name="CommonTokenBox" Padding="6,4" PasswordChanged="OnCommonTokenChanged"/>
                    <TextBlock x:Name="CommonTokenStatus" FontSize="11" Margin="0,4,0,0"/>
                    <TextBlock Text="Used automatically by any repository below that doesn't have its own override token."
                               FontSize="11" Foreground="Gray" TextWrapping="Wrap"/>

                    <Separator Margin="0,14,0,10"/>
                    <TextBlock Text="GitHub Repositories" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <ListBox x:Name="RepoList" Height="120" SelectionChanged="OnRepoSelectionChanged"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="2">
                                    <TextBlock Text="{Binding Name}"/>
                                    <TextBlock Text="{Binding RepositoryUrl}" FontSize="11" Foreground="Gray"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="Add" Padding="12,4" Click="OnRepoAddClick"/>
                        <Button x:Name="FetchButton" Content="Fetch from GitHub…" Padding="12,4" Margin="8,0,0,0"
                                Click="OnRepoFetchClick"/>
                        <Button x:Name="RepoRemoveButton" Content="Remove" Padding="12,4" Margin="8,0,0,0"
                                Click="OnRepoRemoveClick"/>
                    </StackPanel>

                    <StackPanel x:Name="RepoSettingsPanel" Visibility="Collapsed">
                        <Separator Margin="0,14,0,10"/>
                        <TextBlock Text="Repository Settings" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Display Name" VerticalAlignment="Center"/>
                            <TextBox x:Name="RepoNameBox" Grid.Column="1" Padding="4,3" Margin="0,2"
                                     TextChanged="OnRepoFieldChanged"/>
                            <TextBlock Text="Repository URL" Grid.Row="1" VerticalAlignment="Center"/>
                            <TextBox x:Name="RepoUrlBox" Grid.Row="1" Grid.Column="1" Padding="4,3" Margin="0,2"
                                     TextChanged="OnRepoUrlChanged"/>
                            <TextBlock Text="Workflow" Grid.Row="2" VerticalAlignment="Center"/>
                            <TextBox x:Name="RepoWorkflowBox" Grid.Row="2" Grid.Column="1" Padding="4,3" Margin="0,2"
                                     TextChanged="OnRepoFieldChanged"/>
                            <TextBlock Text="Default Branch" Grid.Row="3" VerticalAlignment="Center"/>
                            <TextBox x:Name="RepoBranchBox" Grid.Row="3" Grid.Column="1" Padding="4,3" Margin="0,2"
                                     TextChanged="OnRepoFieldChanged"/>
                            <TextBlock Text="Token override" Grid.Row="4" VerticalAlignment="Center"/>
                            <PasswordBox x:Name="RepoTokenBox" Grid.Row="4" Grid.Column="1" Padding="4,3" Margin="0,2"
                                         PasswordChanged="OnRepoTokenChanged"/>
                        </Grid>
                        <DockPanel Margin="0,4,0,0">
                            <Button x:Name="UseCommonTokenButton" Content="Use common token" DockPanel.Dock="Right"
                                    Padding="10,3" Click="OnUseCommonTokenClick"/>
                            <TextBlock x:Name="RepoTokenStatus" FontSize="11" Foreground="Gray"
                                       VerticalAlignment="Center"/>
                        </DockPanel>
                        <TextBlock Text="Grant only Actions: Read-only and Contents: Read-only for this repository. Press Ctrl+K to return if you opened this from Firmware Flash."
                                   FontSize="11" Foreground="Gray" TextWrapping="Wrap" Margin="0,6,0,0"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <!-- Registered Files -->
        <TabItem Header="Registered Files">
            <StackPanel Margin="18">
                <TextBlock Text="Registered Firmware" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <ListBox x:Name="FirmwareList" Height="160" SelectionChanged="OnFirmwareSelectionChanged"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="2">
                                <TextBlock Text="{Binding Name}"/>
                                <TextBlock Text="{Binding FilePath}" FontSize="11" Foreground="Gray"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <Button Content="Add File…" Padding="12,4" Click="OnFirmwareAddClick"/>
                    <Button x:Name="FirmwareRemoveButton" Content="Remove" Padding="12,4" Margin="8,0,0,0"
                            Click="OnFirmwareRemoveClick"/>
                </StackPanel>

                <StackPanel x:Name="FirmwareSettingsPanel" Visibility="Collapsed">
                    <Separator Margin="0,14,0,10"/>
                    <TextBlock Text="Settings" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <DockPanel>
                        <TextBlock Text="Display Name" Width="150" VerticalAlignment="Center"/>
                        <TextBox x:Name="FirmwareNameBox" Padding="4,3" TextChanged="OnFirmwareNameChanged"/>
                    </DockPanel>
                    <DockPanel Margin="0,6,0,0">
                        <Button Content="Change File…" DockPanel.Dock="Right" Padding="10,3"
                                Click="OnFirmwareChangeFileClick"/>
                        <TextBlock x:Name="FirmwarePathText" FontSize="11" Foreground="Gray"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                    </DockPanel>
                </StackPanel>

                <TextBlock Text="Registered UF2 files can be flashed directly to a UF2 bootloader drive via hotkey. For split keyboards, register the left and right halves separately."
                           FontSize="11" Foreground="Gray" TextWrapping="Wrap" Margin="0,10,0,0"/>
            </StackPanel>
        </TabItem>
    </TabControl>
</Window>
